---
import "aos/dist/aos.css";
import "../styles/globals.css";
import MeshBackground from "../../features/mesh-background/MeshBackground.astro";
import Stardust from "../../features/stardust/Stardust.astro";
import Navbar from "../../features/navbar/Navbar.astro";

export interface Props {
  title?: string;
  description?: string;
}

const { title = "Alexandre Tortoza", description = "Programador" } =
  Astro.props;
---

<!doctype html>
<html lang="pt" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="relative min-h-screen overflow-x-hidden">
    <MeshBackground />
    <Stardust />

    <Navbar />

    <div class="relative z-10 flex min-h-screen flex-col">
      <main class="mx-auto w-full max-w-6xl flex-1 px-6 lg:px-10 2xl:max-w-7xl 3xl:max-w-[1600px] 4xl:max-w-[2100px]">
        <slot />
      </main>

      <footer class="mt-24 border-t border-white/5 py-10 lg:py-16">
        <div class="mx-auto max-w-6xl px-6 text-center text-[10px] tracking-wider text-white/30 uppercase lg:px-10">
          <p>
            Este site está licenciado sob
            <a
              href="https://creativecommons.org/licenses/by-nc-sa/4.0/"
              target="_blank"
              rel="noopener noreferrer"
              class="underline decoration-white/20 hover:decoration-mesh-1 transition-colors hover:text-white/60"
            >
              CC BY-NC-SA 4.0
            </a>
          </p>
          <p class="mt-1">&copy; 2026-PRESENT Alexandre Tortoza.</p>
        </div>
      </footer>
    </div>
  </body>
</html>

<script>
  import AOS from "aos";

  AOS.init({
    duration: 800,
    once: true,
    easing: "ease-out-cubic",
  });
</script>
