---
import "../styles/globals.css";
import MeshBackground from "../../features/mesh-background/MeshBackground.astro";
import Navbar from "../../features/navbar/Navbar.astro";

export interface Props {
  title?: string;
  description?: string;
}

const { title = "Alexandre Tortoza", description = "Desenvolvedor" } =
  Astro.props;
---

<!doctype html>
<html lang="pt" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="relative min-h-screen overflow-x-hidden">
    <MeshBackground />

    <Navbar />

    <div class="relative z-10 flex min-h-screen flex-col">
      <main class="flex-1 w-full">
        <slot />
      </main>

      <footer class="mt-20 border-t border-white/5 py-20 lg:py-32">
        <div class="mx-auto max-w-7xl px-6 text-center text-[10px] tracking-wider text-white/30 uppercase lg:px-10">
          <p>
            Exceto onde otherwise notado, este site está licenciado sob
            <a
              href="https://creativecommons.org/licenses/by-nc-sa/4.0/"
              target="_blank"
              rel="noopener noreferrer"
              class="underline decoration-white/20 hover:decoration-mesh-1 transition-colors hover:text-white/60"
            >
              CC BY-NC-SA 4.0
            </a>
          </p>
          <p class="mt-1">&copy; 2026-PRESENT Alexandre Tortoza.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
