---
import Shine from "../../features/shared/ui/Shine.astro";

const cards = [
  { href: "/photos",   label: "Galeria",  desc: "Fotografia e momentos"   },
  { href: "/blog",     label: "Blog",     desc: "Artigos e anotações"     },
  { href: "/projects", label: "Projetos", desc: "O que estou construindo" },
];
---

<section id="pages-nav" class="py-24 4xl:py-32">
  <h2
    data-aos="fade-up"
    class="mb-16 text-xs tracking-[0.3em] uppercase text-mesh-1 2xl:text-sm 4xl:text-base"
  >
    Explore
  </h2>

  <div class="carousel-scene">
    <div class="carousel-ring">
      {cards.map((card, i) => (
        <a
          href={card.href}
          class="nav-card"
          data-index={i}
          draggable="false"
        >
          <div class="card-3d">
            <div class="card-content">
              <div class="card-iframe-wrapper">
                <iframe
                  data-src={card.href}
                  class="card-iframe"
                  scrolling="no"
                  tabindex="-1"
                  aria-hidden="true"
                />
              </div>

              <div class="card-overlay absolute inset-0 z-10 flex flex-col justify-end p-5 2xl:p-7">
                <span class="mb-1 text-[10px] tracking-[0.25em] uppercase text-mesh-1 2xl:text-xs">
                  {card.label}
                </span>
                <p class="text-sm leading-snug text-white/50 2xl:text-base">
                  {card.desc}
                </p>
              </div>
            </div>

            <Shine />
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="carousel-dots mt-10 flex justify-center gap-2" aria-hidden="true">
    {cards.map((_, i) => (
      <span class="dot rounded-full bg-white/20 transition-all duration-300" data-dot={i} />
    ))}
  </div>
</section>

<style>
  /* ── Scene ──────────────────────────────────────────────────────────────── */
  .carousel-scene {
    perspective: 1200px;
    perspective-origin: 50% 50%;
    height: 320px;
    position: relative;
    user-select: none;
    -webkit-user-select: none;
  }

  @media (max-width: 767px) {
    .carousel-scene { height: 200px; }
  }

  /* ── Ring (rotated by GSAP) ─────────────────────────────────────────────── */
  .carousel-ring {
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    position: relative;
  }

  /* ── Cards: centered absolutely; GSAP sets rotateY + z + scale + opacity ── */
  .nav-card {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 360px;
    margin-left: -180px;
    margin-top: -120px; /* half of 360*(2/3) = 240 */
    transform-style: preserve-3d;
    cursor: grab;
    text-decoration: none;
  }

  .carousel-scene.is-dragging,
  .carousel-scene.is-dragging .nav-card {
    cursor: grabbing;
  }

  @media (max-width: 767px) {
    .nav-card {
      width: 220px;
      margin-left: -110px;
      margin-top: -73px;
    }
  }

  /* ── Inner card: tilt + float ───────────────────────────────────────────── */
  .card-3d {
    --card-tilt-x: 0deg;
    --card-tilt-y: 0deg;
    --card-pull-x: 0px;
    --card-pull-y: 0px;

    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: 2px;
    border: 1px solid rgb(255 255 255 / 0.1);
    background: var(--bg-primary);
    box-shadow: 0 22px 70px rgb(0 0 0 / 0.24);
    transition: box-shadow 600ms ease;
    will-change: transform, translate;

    /* translate (float) and transform (tilt) are independent CSS properties */
    transform: translate3d(var(--card-pull-x), var(--card-pull-y), 0)
      rotateX(var(--card-tilt-x))
      rotateY(var(--card-tilt-y));
    animation: nav-float 8s ease-in-out infinite;
  }

  .nav-card.is-active .card-3d {
    box-shadow:
      0 28px 90px rgb(0 0 0 / 0.34),
      0 0 38px rgb(30 167 182 / 0.08);
  }

  @keyframes nav-float {
    0%, 100% { translate: 0 0; }
    50%       { translate: 0 -10px; }
  }

  /* ── Text overlay ───────────────────────────────────────────────────────── */
  .card-overlay {
    background: linear-gradient(to top, rgb(0 0 0 / 0.72) 0%, transparent 55%);
  }

  /* ── Dots ───────────────────────────────────────────────────────────────── */
  .dot {
    width: 0.375rem;
    height: 0.375rem;
    transition: background-color 0.3s, width 0.3s;
  }
  .dot.active {
    background-color: rgb(30 167 182);
    width: 1.25rem;
  }

  /* ── Card content wrapper ───────────────────────────────────────────────── */
  .card-content {
    position: absolute;
    inset: 0;
  }

  /* ── iframe page preview ─────────────────────────────────────────────────── */
  .card-iframe-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .card-iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 1440px;
    height: 960px;
    border: none;
    transform: scale(0.25);
    transform-origin: top left;
    pointer-events: none;
  }

  @media (max-width: 767px) {
    .card-iframe {
      width: 960px;
      height: 640px;
      transform: scale(0.229);
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ── Config ───────────────────────────────────────────────────────────────
  const N = 3;
  const RADIUS_DESKTOP = 460;
  const RADIUS_MOBILE  = 240;
  const getRadius = () => window.innerWidth < 768 ? RADIUS_MOBILE : RADIUS_DESKTOP;

  // ── State ────────────────────────────────────────────────────────────────
  let currentIndex = 0;
  let ringAngle    = 0; // tracks ring's current visual angle (may accumulate during drag)

  // ── Elements ─────────────────────────────────────────────────────────────
  const scene    = document.querySelector<HTMLElement>(".carousel-scene")!;
  const ring     = document.querySelector<HTMLElement>(".carousel-ring")!;
  const navCards = [...document.querySelectorAll<HTMLElement>(".nav-card")];
  const dots     = [...document.querySelectorAll<HTMLElement>(".dot")];

  // ── Helper: depth factor from effective angle (handles any range) ─────────
  function depthCos(effectiveAngle: number): number {
    const n = ((effectiveAngle % 360) + 360) % 360; // 0..360
    const a = n > 180 ? n - 360 : n;                // -180..180
    return Math.cos(a * Math.PI / 180);              // -1..1
  }

  // ── Place cards on the ring ───────────────────────────────────────────────
  // GSAP applies transforms as: translate → rotate → scale.
  // The classic CSS carousel uses `rotateY(θ) translateZ(R)` (rotate THEN translate),
  // which cannot be replicated with GSAP's individual properties.
  // Solution: pre-compute the XZ position in the parent's space using trigonometry
  // so that `translate3d(x,0,z) rotateY(θ)` produces the same result as
  // `rotateY(θ) translateZ(R)` for each card.
  function initPositions() {
    const R = getRadius();
    gsap.set(ring, { transformStyle: "preserve-3d" });
    navCards.forEach((card, i) => {
      const rad = (i * 120 * Math.PI) / 180;
      gsap.set(card, {
        x: R * Math.sin(rad),   // lateral offset
        z: R * Math.cos(rad),   // depth offset
        rotateY: i * 120,       // face outward
        transformOrigin: "50% 50%",
        transformStyle: "preserve-3d",
      });
    });
  }

  // ── Apply scale/opacity/isActive for a given ring angle (no ring anim) ───
  function applyDepth(angle: number) {
    navCards.forEach((card, i) => {
      const cos = depthCos(angle + i * 120);
      const t   = (cos + 1) / 2;
      gsap.set(card, { scale: 0.72 + 0.28 * t, opacity: 0.30 + 0.70 * t });
      card.classList.toggle("is-active", cos > 0.5);
    });
    dots.forEach((d, j) => d.classList.toggle("active", j === currentIndex));
  }

  // ── Instant update during drag (no tweens) ────────────────────────────────
  function dragUpdate(angle: number) {
    gsap.set(ring, { rotateY: angle, transformStyle: "preserve-3d" });
    applyDepth(angle);
  }

  // ── Snap to a card index with smooth animation ────────────────────────────
  function snapTo(index: number) {
    currentIndex = ((index % N) + N) % N;
    const canonical = -currentIndex * 120;

    // Shortest angular path from current visual angle to canonical
    const visual = (gsap.getProperty(ring, "rotateY") as number) || ringAngle;
    let delta    = canonical - (visual % 360);
    if (delta >  180) delta -= 360;
    if (delta < -180) delta += 360;
    const target = visual + delta;

    ringAngle = canonical;

    const dur  = 0.65;
    const ease = "power3.out";

    gsap.to(ring, {
      rotateY: target,
      duration: dur,
      ease,
      onComplete: () => gsap.set(ring, { rotateY: canonical, transformStyle: "preserve-3d" }),
    });

    navCards.forEach((card, i) => {
      const cos = depthCos(canonical + i * 120);
      const t   = (cos + 1) / 2;
      gsap.to(card, { scale: 0.72 + 0.28 * t, opacity: 0.30 + 0.70 * t, duration: dur, ease });
      card.classList.toggle("is-active", cos > 0.5);
    });

    dots.forEach((d, j) => d.classList.toggle("active", j === currentIndex));
  }

  // ── Drag ─────────────────────────────────────────────────────────────────
  let dragging   = false;
  let startX     = 0;
  let startAngle = 0;
  let dragDelta  = 0;
  const SENS     = 0.35; // deg per px

  scene.addEventListener("pointerdown", (e) => {
    dragging   = true;
    dragDelta  = 0;
    startX     = e.clientX;
    startAngle = ringAngle;
    scene.classList.add("is-dragging");
    scene.setPointerCapture(e.pointerId);
    gsap.killTweensOf(ring);
    navCards.forEach((c) => gsap.killTweensOf(c));
  });

  scene.addEventListener("pointermove", (e) => {
    if (!dragging) return;
    const dx  = e.clientX - startX;
    dragDelta = Math.abs(dx);
    ringAngle = startAngle - dx * SENS;
    dragUpdate(ringAngle);
  });

  scene.addEventListener("pointerup", (e) => {
    if (!dragging) return;
    dragging = false;
    scene.classList.remove("is-dragging");

    if (dragDelta > 6) {
      // Was a real drag — snap to nearest card
      const dx      = e.clientX - startX;
      const nearest = Math.abs(dx) > 30
        ? Math.round(-ringAngle / 120)
        : currentIndex;
      snapTo(nearest);
      return;
    }

    // Was a click — use X-zone to decide action
    const rect = scene.getBoundingClientRect();
    const relX = (e.clientX - rect.left) / rect.width;

    if (relX < 0.30) {
      snapTo(currentIndex - 1);
    } else if (relX > 0.70) {
      snapTo(currentIndex + 1);
    } else {
      const activeCard = navCards.find((c) => c.classList.contains("is-active"));
      if (activeCard) {
        navigateWithZoom(activeCard, activeCard.getAttribute("href")!);
      }
    }
  });

  // Prevent <a> default navigation — all routing is handled via pointerup
  scene.addEventListener("click", (e) => { e.preventDefault(); });

  scene.addEventListener("pointercancel", () => {
    if (dragging) { dragging = false; scene.classList.remove("is-dragging"); snapTo(currentIndex); }
  });

  // ── Navigate with zoom (clone expands to fill screen, then navigates) ──────
  function navigateWithZoom(navCard: HTMLElement, href: string) {
    const card3d = navCard.querySelector<HTMLElement>(".card-3d")!;
    const rect   = card3d.getBoundingClientRect();

    const clone = document.createElement("div");
    Object.assign(clone.style, {
      position:        "fixed",
      left:            rect.left   + "px",
      top:             rect.top    + "px",
      width:           rect.width  + "px",
      height:          rect.height + "px",
      zIndex:          "9999",
      borderRadius:    "2px",
      border:          "1px solid rgba(255,255,255,0.1)",
      overflow:        "hidden",
      pointerEvents:   "none",
      backgroundColor: "var(--bg-primary)",
    });
    const overlay = document.createElement("div");
    overlay.style.cssText =
      "position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.72),transparent 55%);";
    clone.appendChild(overlay);
    document.body.appendChild(clone);

    const scaleX = window.innerWidth  / rect.width;
    const scaleY = window.innerHeight / rect.height;
    const scale  = Math.max(scaleX, scaleY) * 1.05;
    const dx = window.innerWidth  / 2 - (rect.left + rect.width  / 2);
    const dy = window.innerHeight / 2 - (rect.top  + rect.height / 2);

    gsap.to(clone, {
      x: dx, y: dy,
      scale,
      borderRadius: 0,
      duration: 0.45,
      ease: "power2.in",
      onComplete: () => { window.location.href = href; },
    });
  }

  // ── 3D Tilt (active card only) ───────────────────────────────────────────
  interface TiltState { pullX: number; pullY: number; tiltX: number; tiltY: number; }
  const cardStates = new Map<HTMLElement, { cur: TiltState; tgt: TiltState }>();

  navCards.forEach((navCard) => {
    const inner = navCard.querySelector<HTMLElement>(".card-3d");
    if (!inner) return;

    const state = {
      cur: { pullX: 0, pullY: 0, tiltX: 0, tiltY: 0 },
      tgt: { pullX: 0, pullY: 0, tiltX: 0, tiltY: 0 },
    };
    cardStates.set(inner, state);

    const reset = () => {
      state.tgt.pullX = state.tgt.pullY = state.tgt.tiltX = state.tgt.tiltY = 0;
    };

    navCard.addEventListener("pointerleave", reset);
    navCard.addEventListener("pointermove", (e) => {
      if (!navCard.classList.contains("is-active")) { reset(); return; }
      const rect = inner.getBoundingClientRect();
      const dx   = e.clientX - (rect.left + rect.width  / 2);
      const dy   = e.clientY - (rect.top  + rect.height / 2);
      const rng  = Math.min(rect.width, rect.height) * 1.2;
      const dist = Math.hypot(dx, dy);
      if (dist > rng) { reset(); return; }
      const inf  = 1 - dist / rng;
      const nx   = Math.max(-1, Math.min(1, dx / rng));
      const ny   = Math.max(-1, Math.min(1, dy / rng));
      state.tgt.tiltX  = ny * -12;
      state.tgt.tiltY  = nx *  16;
      state.tgt.pullX  = nx * inf * 24;
      state.tgt.pullY  = ny * inf * 24;
    });
  });

  const EASE_F = 0.09;
  gsap.ticker.add(() => {
    cardStates.forEach(({ cur, tgt }, inner) => {
      cur.pullX += (tgt.pullX - cur.pullX) * EASE_F;
      cur.pullY += (tgt.pullY - cur.pullY) * EASE_F;
      cur.tiltX += (tgt.tiltX - cur.tiltX) * EASE_F;
      cur.tiltY += (tgt.tiltY - cur.tiltY) * EASE_F;
      inner.style.setProperty("--card-tilt-x", `${cur.tiltX}deg`);
      inner.style.setProperty("--card-tilt-y", `${cur.tiltY}deg`);
      inner.style.setProperty("--card-pull-x", `${cur.pullX}px`);
      inner.style.setProperty("--card-pull-y", `${cur.pullY}px`);
    });
  });

  // ── Load iframes immediately on section enter ────────────────────────────
  const iframeObserver = new IntersectionObserver(([entry]) => {
    if (!entry.isIntersecting) return;
    iframeObserver.disconnect();
    document.querySelectorAll<HTMLIFrameElement>(".card-iframe").forEach((iframe) => {
      iframe.src = iframe.dataset.src!;
    });
  }, { threshold: 0.1 });
  iframeObserver.observe(document.getElementById("pages-nav")!);

  // ── Init + ScrollTrigger entrance ────────────────────────────────────────
  initPositions();
  applyDepth(0);
  gsap.set(ring, { rotateY: 0, transformStyle: "preserve-3d" });

  gsap.from(scene, {
    scrollTrigger: { trigger: "#pages-nav", start: "top 82%", once: true },
    opacity: 0,
    scale: 0.88,
    duration: 1.0,
    ease: "power3.out",
  });

  // ── Resize ────────────────────────────────────────────────────────────────
  window.addEventListener("resize", () => {
    initPositions();
    applyDepth(ringAngle);
  });

  // ── Cleanup on page navigation ────────────────────────────────────────────
  document.addEventListener("astro:before-swap", () => {
    cardStates.clear();
  });
</script>
