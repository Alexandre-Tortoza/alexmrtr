---
import type { PostListItem } from "../api/posts.ts";
import { formatDate } from "../api/posts.ts";

export interface Props {
  post: PostListItem;
}

const { post } = Astro.props;
---

<article class="group rounded-sm border border-white/5 bg-white/[0.03] backdrop-blur-md p-6 transition-all hover:border-mesh-1/30 hover:bg-white/[0.06]">
  <div class="mb-3 flex items-center gap-2 text-[10px] tracking-wider text-white/40 uppercase">
    <time datetime={post.meta.pubDate.toISOString()}>
      {formatDate(post.meta.pubDate)}
    </time>
    {post.meta.tags.length > 0 && (
      <>
        <span>·</span>
        <span>{post.meta.tags[0]}</span>
      </>
    )}
  </div>

  <h2 class="mb-2 text-base font-medium text-white/90 transition-colors group-hover:text-mesh-1">
    <a href={`/blog/${post.slug}`} class="after:absolute after:inset-0">
      {post.meta.title}
    </a>
  </h2>

  <p class="text-xs leading-relaxed text-white/50">
    {post.meta.description}
  </p>
</article>
