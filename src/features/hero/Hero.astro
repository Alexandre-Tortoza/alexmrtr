---
import AsciiArt from "../ascii-art/AsciiArt.astro";
import Container from "../container/Container.astro";
---

<section class="grid sm:min-h-screen w-full grid-cols-1 items-center gap-8 pt-32 pb-16 sm:gap-14 sm:py-24 md:grid-cols-2 md:gap-10 3xl:gap-16 4xl:gap-32 4xl:py-32">
  <div class="mx-auto flex w-full max-w-full sm:max-w-md flex-col items-start gap-8 text-balance text-left md:mx-0 2xl:max-w-xl 3xl:max-w-3xl 4xl:max-w-5xl 4xl:gap-12">
    <p id="hero-subtitle" class="text-xs tracking-[0.3em] uppercase text-mesh-1 2xl:text-sm 4xl:text-base">
      Alexandre Tortoza
    </p>

    <h1 id="hero-title" class="text-5xl font-light tracking-tight sm:text-6xl 2xl:text-8xl 3xl:text-[110px] 4xl:text-[130px]">
      <span id="hero-role">Programador</span>
    </h1>

    <p id="hero-quote" class="max-w-sm text-sm italic leading-relaxed text-white/30 xl:max-w-md 2xl:max-w-xl 3xl:max-w-2xl 4xl:max-w-3xl 4xl:text-base">
      <span id="typewriter-text"></span>
      <span id="hero-attribution" class="block mt-1 not-italic text-[10px] tracking-wider text-white/20 uppercase opacity-0 2xl:text-xs 4xl:text-sm">— Frederick Brooks</span>
    </p>
  </div>


  <div id="hero-card" class="hero-card-3d order-first md:order-last mx-auto md:mx-0 md:justify-self-center 4xl:justify-self-end">
    <Container class="max-w-md">
      <div class="relative h-full w-full overflow-hidden p-3">
        <AsciiArt
          src="/me.jpg"
          width="100%"
          height="100%"
          class="h-full w-full rounded-[2px]"
          fontSize={20}
          artStyle="classic"
          colorMode="fullcolor"
          ditherStrength={0}
        />
        <img
          src="/me.jpg"
          alt=""
          class="hero-card-real-img absolute inset-0 h-full w-full object-cover rounded-[2px] opacity-0 pointer-events-none transition-opacity duration-700"
        />
      </div>
    </Container>
  </div>
</section>

<style>
  .hero-card-3d {
    --card-tilt-x: 0deg;
    --card-tilt-y: 0deg;
    --card-pull-x: 0px;
    --card-pull-y: 0px;

    cursor: pointer;
    position: relative;
    width: 100%;
    max-width: min(34rem, 100%);
    overflow: hidden;
    border-radius: 2px;
    transform: translate3d(var(--card-pull-x), var(--card-pull-y), 0)
      perspective(900px) rotateX(var(--card-tilt-x))
      rotateY(var(--card-tilt-y));
    transform-style: preserve-3d;
    transition: box-shadow 600ms ease;
    animation: card-float 8s ease-in-out infinite;
    box-shadow: 0 22px 70px rgb(0 0 0 / 0.24);
    will-change: transform, translate;
  }

  @media (max-width: 767px) {
    .hero-card-3d {
      max-width: min(14rem, 100%);
    }
  }

  @media (min-width: 1536px) {
    .hero-card-3d {
      max-width: min(44rem, 100%);
    }
  }

  @media (min-width: 1920px) {
    .hero-card-3d {
      max-width: min(50rem, 100%);
    }
  }

  @media (min-width: 2440px) {
    .hero-card-3d {
      max-width: min(56rem, 100%);
    }
  }

  .hero-card-3d::after {
    position: absolute;
    inset: -45%;
    z-index: 2;
    pointer-events: none;
    content: "";
    background: linear-gradient(
      115deg,
      transparent 38%,
      rgb(255 255 255 / 0.06) 44%,
      rgb(30 167 182 / 0.24) 50%,
      rgb(255 255 255 / 0.08) 56%,
      transparent 64%
    );
    transform: translateX(-45%) rotate(8deg);
    animation: card-shine 8s ease-in-out infinite;
  }

  .hero-card-3d canvas {
    display: block;
    opacity: 0.86;
  }

  .hero-card-3d:hover {
    box-shadow:
      0 28px 90px rgb(0 0 0 / 0.34),
      0 0 38px rgb(30 167 182 / 0.08);
  }

  .hero-card-3d:hover .hero-card-real-img {
    opacity: 0.22;
  }

  @keyframes card-float {
    0%,
    100% {
      translate: 0 0;
    }

    50% {
      translate: 0 -10px;
    }
  }

  @keyframes card-shine {
    0%,
    45% {
      opacity: 0;
      transform: translateX(-45%) rotate(8deg);
    }

    55% {
      opacity: 1;
    }

    100% {
      opacity: 0;
      transform: translateX(45%) rotate(8deg);
    }
  }
</style>

<script>
  const card = document.querySelector<HTMLElement>(".hero-card-3d");

  import { animateHero } from "./heroAnimation.ts";
  animateHero();

  if (card) {
    const current = {
      pullX: 0,
      pullY: 0,
      tiltX: 0,
      tiltY: 0,
    };
    const target = {
      pullX: 0,
      pullY: 0,
      tiltX: 0,
      tiltY: 0,
    };
    const ease = 0.045;

    const resetCard = () => {
      target.pullX = 0;
      target.pullY = 0;
      target.tiltX = 0;
      target.tiltY = 0;
    };

    const animateCard = () => {
      current.pullX += (target.pullX - current.pullX) * ease;
      current.pullY += (target.pullY - current.pullY) * ease;
      current.tiltX += (target.tiltX - current.tiltX) * ease;
      current.tiltY += (target.tiltY - current.tiltY) * ease;

      card.style.setProperty("--card-tilt-x", `${current.tiltX}deg`);
      card.style.setProperty("--card-tilt-y", `${current.tiltY}deg`);
      card.style.setProperty("--card-pull-x", `${current.pullX}px`);
      card.style.setProperty("--card-pull-y", `${current.pullY}px`);

      requestAnimationFrame(animateCard);
    };

    window.addEventListener("pointermove", (event) => {
      const rect = card.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;
      const deltaX = event.clientX - centerX;
      const deltaY = event.clientY - centerY;
      const distance = Math.hypot(deltaX, deltaY);
      const range = 720;

      if (distance > range) {
        resetCard();
        return;
      }

      const influence = 1 - distance / range;
      const nx = Math.max(-1, Math.min(1, deltaX / range));
      const ny = Math.max(-1, Math.min(1, deltaY / range));

      target.tiltX = ny * -18;
      target.tiltY = nx * 22;
      target.pullX = nx * influence * 42;
      target.pullY = ny * influence * 42;
    });

    document.addEventListener("mouseleave", resetCard);
    animateCard();
  }

  import { cycleHeroRole } from "./heroRoleCycle.ts";

  const roleEl = document.getElementById("hero-role");
  if (roleEl) cycleHeroRole(roleEl);

  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { TextPlugin } from "gsap/TextPlugin";

  gsap.registerPlugin(ScrollTrigger, TextPlugin);

  const quote =
    "\"O programador, como o poeta, trabalha apenas ligeiramente afastado do puro pensamento. Constrói seus castelos no ar, a partir do ar, criando com esforço da imaginação.\"";

  const textEl = document.getElementById("typewriter-text");
  const attrEl = document.getElementById("hero-attribution");

  if (textEl && attrEl) {
    ScrollTrigger.create({
      trigger: textEl,
      start: "top 85%",
      once: true,
      onEnter: () => {
        gsap.to(textEl, {
          text: quote,
          duration: 3,
          ease: "none",
          delay: 0.3,
          onComplete: () => {
            gsap.to(attrEl, { opacity: 1, y: 0, duration: 0.6 });
          },
        });
      },
    });
  }
</script>
