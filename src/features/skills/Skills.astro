---
---

<section id="skills" class="w-full py-24 2xl:py-40">
  <div class="mb-16 flex flex-col items-center gap-4 text-center">
    <h2 class="text-3xl font-light tracking-tight sm:text-4xl 2xl:text-6xl">
      Tech <span class="text-mesh-1">Stack</span>
    </h2>
    <div class="h-px w-20 bg-mesh-1/50 2xl:w-32"></div>
  </div>

  <div class="mx-auto max-w-4xl overflow-hidden rounded-lg border border-white/10 bg-black/40 backdrop-blur-md shadow-2xl">
    <!-- Terminal Header -->
    <div class="flex items-center justify-between border-b border-white/5 bg-white/[0.03] px-4 py-3">
      <div class="flex gap-2">
        <div class="h-3 w-3 rounded-full bg-red-500/20 border border-red-500/40"></div>
        <div class="h-3 w-3 rounded-full bg-yellow-500/20 border border-yellow-500/40"></div>
        <div class="h-3 w-3 rounded-full bg-green-500/20 border border-green-500/40"></div>
      </div>
      <span class="text-[10px] tracking-widest text-white/20 uppercase">bash — skills.sh</span>
      <div class="w-12"></div>
    </div>

    <!-- Terminal Body -->
    <div class="p-6 font-mono text-xs leading-relaxed sm:p-10 sm:text-sm lg:text-base">
      <div class="space-y-8">
        <!-- Languages -->
        <div class="skill-category opacity-0 translate-y-4">
          <div class="flex items-center gap-2 text-mesh-1 mb-4">
            <span class="text-white/40">></span>
            <span class="font-bold">Languages</span>
          </div>
          <div class="grid grid-cols-2 gap-x-4 gap-y-3 sm:grid-cols-3 md:grid-cols-4">
            {["TypeScript", "JavaScript", "HTML5", "CSS3", "Node.js"].map(skill => (
              <div class="skill-item group flex items-center gap-2 text-white/60 hover:text-white transition-colors cursor-default">
                <span class="text-[10px] text-mesh-1 opacity-0 group-hover:opacity-100 transition-opacity">#</span>
                <span>{skill}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Frameworks -->
        <div class="skill-category opacity-0 translate-y-4">
          <div class="flex items-center gap-2 text-mesh-1 mb-4">
            <span class="text-white/40">></span>
            <span class="font-bold">Frameworks & Libs</span>
          </div>
          <div class="grid grid-cols-2 gap-x-4 gap-y-3 sm:grid-cols-3 md:grid-cols-4">
            {["Astro", "React", "GSAP", "Three.js", "TailwindCSS", "Next.js"].map(skill => (
              <div class="skill-item group flex items-center gap-2 text-white/60 hover:text-white transition-colors cursor-default">
                <span class="text-[10px] text-mesh-1 opacity-0 group-hover:opacity-100 transition-opacity">#</span>
                <span>{skill}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Tools -->
        <div class="skill-category opacity-0 translate-y-4">
          <div class="flex items-center gap-2 text-mesh-1 mb-4">
            <span class="text-white/40">></span>
            <span class="font-bold">Tools & Env</span>
          </div>
          <div class="grid grid-cols-2 gap-x-4 gap-y-3 sm:grid-cols-3 md:grid-cols-4">
            {["Git", "Vite", "PNPM", "VS Code", "Linux", "Figma"].map(skill => (
              <div class="skill-item group flex items-center gap-2 text-white/60 hover:text-white transition-colors cursor-default">
                <span class="text-[10px] text-mesh-1 opacity-0 group-hover:opacity-100 transition-opacity">#</span>
                <span>{skill}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Prompt -->
        <div class="flex items-center gap-2 pt-4">
          <span class="text-green-500/70">alex@torts</span>
          <span class="text-white/40">:</span>
          <span class="text-mesh-1">~</span>
          <span class="text-white/40">$</span>
          <span class="skill-cursor h-5 w-2 bg-mesh-1 animate-pulse"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .skill-cursor {
    animation: blink 1s step-end infinite;
    display: inline-block;
    vertical-align: middle;
  }

  .skill-item:hover {
    text-shadow: 0 0 12px rgba(30, 167, 182, 0.4);
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const categories = document.querySelectorAll(".skill-category");

  if (categories.length > 0) {
    gsap.to(categories, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#skills",
        start: "top 75%",
        once: true
      }
    });
  }
</script>
