---
---

<section id="skills" class="w-full py-24 2xl:py-40">
  <div class="mb-16 flex flex-col items-start gap-4 text-left">
    <h2 class="text-3xl font-light tracking-tight sm:text-4xl 2xl:text-6xl">
      Tech <span class="text-mesh-1">Stack</span>
    </h2>
  </div>

  <div class="mx-auto max-w-4xl overflow-hidden rounded-lg border border-white/10 bg-black/40 shadow-2xl 2xl:max-w-5xl 4xl:max-w-6xl">
    <!-- Terminal Header -->
    <button
      id="terminal-toggle"
      type="button"
      class="flex w-full cursor-pointer items-center justify-between border-b border-white/5 bg-white/[0.03] px-4 py-3 transition-colors hover:bg-white/[0.06]"
    >
      <div class="flex gap-2">
        <span class="inline-block h-3 w-3 rounded-full border border-red-500/40 bg-red-500/20"></span>
        <span class="inline-block h-3 w-3 rounded-full border border-yellow-500/40 bg-yellow-500/20"></span>
        <span class="inline-block h-3 w-3 rounded-full border border-green-500/40 bg-green-500/20"></span>
      </div>
      <span class="text-[10px] tracking-widest text-white/20 uppercase">bash — skills.sh</span>
      <span id="terminal-chevron" class="inline-block text-xs text-white/30 transition-transform duration-300">▼</span>
    </button>

    <!-- Terminal Body -->
    <div id="terminal-body" class="overflow-hidden" style="height: 0;">
      <div id="terminal-inner" class="p-6 font-mono text-xs leading-relaxed text-left sm:p-10 sm:text-sm lg:text-base">
        <!-- Languages -->
        <div class="category mb-4" data-open="false">
          <button
            type="button"
            class="category-toggle flex w-full cursor-pointer items-center justify-start gap-2 text-mesh-1 transition-colors hover:text-white"
          >
            <span class="arrow inline-block text-[10px] transition-transform duration-300">▶</span>
            <span class="font-bold">Languages</span>
            <span class="text-white/40">&gt;</span>
          </button>
          <div class="category-content overflow-hidden" style="height: 0;">
            <div class="flex flex-wrap justify-start gap-x-4 gap-y-2 pb-4 pt-2">
              {["TypeScript", "JavaScript", "HTML5", "CSS3", "Node.js"].map(skill => (
                <span class="cursor-default text-white/60 transition-colors hover:text-white">{skill}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Frameworks -->
        <div class="category mb-4" data-open="false">
          <button
            type="button"
            class="category-toggle flex w-full cursor-pointer items-center justify-start gap-2 text-mesh-1 transition-colors hover:text-white"
          >
            <span class="arrow inline-block text-[10px] transition-transform duration-300">▶</span>
            <span class="font-bold">Frameworks & Libs</span>
            <span class="text-white/40">&gt;</span>
          </button>
          <div class="category-content overflow-hidden" style="height: 0;">
            <div class="flex flex-wrap justify-start gap-x-4 gap-y-2 pb-4 pt-2">
              {["Astro", "React", "GSAP", "Three.js", "TailwindCSS", "Next.js"].map(skill => (
                <span class="cursor-default text-white/60 transition-colors hover:text-white">{skill}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Tools -->
        <div class="category mb-4" data-open="false">
          <button
            type="button"
            class="category-toggle flex w-full cursor-pointer items-center justify-start gap-2 text-mesh-1 transition-colors hover:text-white"
          >
            <span class="arrow inline-block text-[10px] transition-transform duration-300">▶</span>
            <span class="font-bold">Tools & Env</span>
            <span class="text-white/40">&gt;</span>
          </button>
          <div class="category-content overflow-hidden" style="height: 0;">
            <div class="flex flex-wrap justify-start gap-x-4 gap-y-2 pb-4 pt-2">
              {["Git", "Vite", "PNPM", "VS Code", "Linux", "Figma"].map(skill => (
                <span class="cursor-default text-white/60 transition-colors hover:text-white">{skill}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Final Prompt -->
        <div
          id="final-prompt"
          class="mt-8 border-t border-white/5 pt-4 text-white/40"
        >
          <span class="text-green-500/70">eriophorum@alexmrtr</span>
          <span class="text-mesh-1">~</span>
          <span class="text-white/40">/skills</span>
          <span class="ml-1 inline-block h-5 w-2 animate-blink bg-mesh-1 align-middle"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .animate-blink {
    animation: blink 1s step-end infinite;
  }

  .category-toggle:focus-visible {
    outline: 1px solid rgb(30 167 182 / 0.5);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const terminalBody = document.getElementById("terminal-body");
  const terminalInner = document.getElementById("terminal-inner");
  const terminalToggle = document.getElementById("terminal-toggle");
  const terminalChevron = document.getElementById("terminal-chevron");
  const finalPrompt = document.getElementById("final-prompt");
  const categories = document.querySelectorAll(".category");

  if (
    terminalBody &&
    terminalInner &&
    terminalToggle &&
    terminalChevron &&
    finalPrompt &&
    categories.length > 0
  ) {
    let bodyOpen = true;
    let revealed = false;

    // Measure full expanded height before collapsing via GSAP
    document.querySelectorAll(".category-content").forEach((el) => {
      el.style.height = "auto";
    });
    terminalBody.style.height = "auto";
    const totalHeight = terminalInner.scrollHeight;
    terminalBody.style.height = "0";
    document.querySelectorAll(".category-content").forEach((el) => {
      el.style.height = "0";
    });

    // Initial GSAP states
    gsap.set(terminalBody, { height: 0 });
    gsap.set(finalPrompt, { opacity: 0, x: -20 });
    categories.forEach((cat) => {
      const header = cat.querySelector(".category-toggle");
      if (header) gsap.set(header, { opacity: 0, x: -20 });
    });

    // Scroll-triggered reveal timeline
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#skills",
        start: "top 75%",
        once: true,
      },
      onComplete: () => {
        revealed = true;

        categories.forEach((cat) => {
          const header = cat.querySelector(".category-toggle");
          if (header) {
            gsap.set(header, { clearProps: "opacity,x" });
          }
        });
      },
    });

    tl.to(terminalBody, {
      height: totalHeight,
      duration: 0.6,
      ease: "power3.out",
      onComplete: () => {
        terminalBody.style.height = "auto";
      },
    });

    categories.forEach((cat) => {
      const header = cat.querySelector(".category-toggle");
      const content = cat.querySelector(".category-content");
      const arrow = cat.querySelector(".arrow");

      if (!header || !content || !arrow) return;

      const contentHeight = content.scrollHeight;

      tl.to(header, { opacity: 1, x: 0, duration: 0.3 }, "+=0.15");
      tl.to(
        content,
        {
          height: contentHeight,
          duration: 0.4,
          ease: "power3.out",
          onComplete: () => {
            content.style.height = "auto";
            cat.dataset.open = "true";
          },
        },
        "-=0.1",
      );
      tl.to(arrow, { rotate: 90, duration: 0.3 }, "-=0.35");
    });

    tl.to(finalPrompt, { opacity: 1, x: 0, duration: 0.5 }, "+=0.2");

    // Terminal header toggle (collapse/expand all)
    terminalToggle.addEventListener("click", () => {
      if (!revealed) return;

      if (bodyOpen) {
        terminalBody.style.height = `${terminalBody.scrollHeight}px`;
        void terminalBody.offsetHeight;

        gsap.to(terminalBody, {
          height: 0,
          duration: 0.4,
          ease: "power2.in",
          overwrite: "auto",
          onComplete: () => {
            bodyOpen = false;
            terminalChevron.style.transform = "rotate(180deg)";
          },
        });
      } else {
        gsap.to(terminalBody, {
          height: terminalInner.scrollHeight,
          duration: 0.5,
          ease: "power3.out",
          overwrite: "auto",
          onComplete: () => {
            terminalBody.style.height = "auto";
            bodyOpen = true;
            terminalChevron.style.transform = "rotate(0deg)";
          },
        });
      }
    });

    // Category header toggles
    categories.forEach((cat) => {
      const header = cat.querySelector(".category-toggle");
      const content = cat.querySelector(".category-content");
      const arrow = cat.querySelector(".arrow");

      if (!header || !content || !arrow) return;

      header.addEventListener("click", () => {
        if (!revealed) return;

        const isOpen = cat.dataset.open === "true";

        if (isOpen) {
          cat.dataset.open = "false";
          gsap.to(arrow, { rotate: 0, duration: 0.3, overwrite: "auto" });
          gsap.to(content, {
            height: 0,
            duration: 0.3,
            ease: "power2.in",
            overwrite: "auto",
          });
        } else {
          cat.dataset.open = "true";
          gsap.to(arrow, { rotate: 90, duration: 0.3, overwrite: "auto" });
          gsap.to(content, {
            height: content.scrollHeight,
            duration: 0.4,
            ease: "power3.out",
            overwrite: "auto",
            onComplete: () => {
              content.style.height = "auto";
            },
          });
        }
      });
    });

    // Cleanup on Astro SPA navigation
    document.addEventListener("astro:before-swap", () => {
      ScrollTrigger.getAll().forEach((st) => st.kill());
    });
  }
</script>
