<canvas
  id="about-bg"
  class="absolute inset-0 -z-10 h-full w-full pointer-events-none scale-110 "
  style="mask-image: radial-gradient(circle, black 30%, transparent 90%);"
></canvas>

<script>
  import { createBinaryStars } from "./binaryStars.ts";

  function init() {
    const canvas = document.getElementById("about-bg");
    if (canvas instanceof HTMLCanvasElement) {
      const cleanup = createBinaryStars(canvas);

      document.addEventListener("astro:before-swap", () => {
        if (cleanup) cleanup();
      }, { once: true });
    }
  }

  // Initialize on first load
  init();

  // Re-initialize after Astro navigation
  document.addEventListener("astro:after-swap", init);
</script>
