<div
  id="lava-lamp"
  class="fixed inset-0 -z-20 pointer-events-none overflow-hidden"
  style="mix-blend-mode: screen;"
/>

<script>
  import { createLavaLamp } from "./lavaLamp.ts";

  const container = document.getElementById("lava-lamp");
  if (container) {
    const cleanup = createLavaLamp(container);

    document.addEventListener("astro:before-swap", () => {
      if (cleanup) cleanup();
    });
  }
</script>
