---
import BaseLayout from "../../app/layouts/BaseLayout.astro";
---

<BaseLayout title="Fotos — Alexandre Tortoza" description="Em breve: Registros fotográficos e momentos.">
  <div class="flex min-h-[calc(100vh-200px)] items-center justify-center py-12">
    <div class="flex h-full min-h-[400px] w-full items-center justify-center rounded-sm border border-white/5 bg-white/[0.03] backdrop-blur-md">
      <div class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-8 py-4 backdrop-blur-sm">
        <span class="text-xs font-bold tracking-[0.3em] uppercase text-white/80">
          Galeria em Construção 🏗️
        </span>
      </div>
    </div>
  </div>
</BaseLayout>
