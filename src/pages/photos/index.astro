---
import BaseLayout from "../../app/layouts/BaseLayout.astro";
import VirtualGallery from "../../features/gallery/ui/VirtualGallery.astro";
import photos from "../../features/gallery/data/photos.json";
---

<BaseLayout
  title="Galeria — Alexandre Tortoza"
  description="Registros fotográficos e momentos."
>
  <div
    class="page-hero relative mt-20 h-[55vh] w-full overflow-hidden rounded-sm border border-white/10"
  >
    <img
      src="/gallery/tempestade-entardecer.jpg"
      alt="Galeria"
      fetchpriority="high"
      decoding="async"
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
    <div class="absolute bottom-0 left-0 p-6 lg:p-10">
      <p class="text-[10px] tracking-[0.25em] uppercase text-mesh-1 mb-1">
        Galeria
      </p>
      <h1 class="text-3xl font-light tracking-tight text-white/90 lg:text-5xl">
        Fotografia e momentos
      </h1>
    </div>
    <button
      id="clear-gallery"
      class="absolute top-6 right-6 z-50 rounded-sm border border-white/10 bg-white/5 px-4 py-2 text-[10px] uppercase tracking-wider text-white/80 backdrop-blur-sm transition-colors hover:bg-white/10"
    >
      Limpar Coleção
    </button>
  </div>

  <section class="py-16 lg:py-24">
    <VirtualGallery photos={photos} />
  </section>
</BaseLayout>

<script>
  const clearBtn = document.getElementById("clear-gallery");
  clearBtn?.addEventListener("click", () => {
    Object.keys(localStorage).forEach((key) => {
      if (key.startsWith("photo-unlocked-")) {
        localStorage.removeItem(key);
      }
    });
    location.reload();
  });
</script>

<style>
  .page-hero {
    animation: hero-enter 0.5s ease-out both;
    animation-delay: 0.05s;
  }
  @keyframes hero-enter {
    from { opacity: 0; transform: scale(1.06); }
    to   { opacity: 1; transform: scale(1); }
  }
</style>
