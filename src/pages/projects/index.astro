---
import BaseLayout from "../../app/layouts/BaseLayout.astro";
import penguinsImage from "../../assets/hubert-neufeld-j-udI4zim2E-unsplash.jpg";
---

<BaseLayout
  title="Projetos — Alexandre Tortoza"
  description="Galeria de projetos e experimentos técnicos."
>
  <div class="page-hero relative mt-20 h-[55vh] w-full overflow-hidden rounded-sm border border-white/10">
    <img
      src={penguinsImage.src}
      alt="Projetos"
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
    <div class="absolute bottom-0 left-0 p-6 lg:p-10">
      <p class="text-[10px] tracking-[0.25em] uppercase text-mesh-1 mb-1">
        Projetos
      </p>
      <h1 class="text-3xl font-light tracking-tight text-white/90 lg:text-5xl">
        O que estou construindo
      </h1>
    </div>
  </div>

  <div class="mt-12 flex min-h-[300px] items-center justify-center rounded-sm border border-white/5 bg-white/[0.03]">
    <div class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-8 py-4 backdrop-blur-sm">
      <span class="text-xs font-bold tracking-[0.3em] uppercase text-white/80">
        Em construção
      </span>
    </div>
  </div>
</BaseLayout>

<style>
  .page-hero {
    animation: hero-enter 0.5s ease-out both;
    animation-delay: 0.05s;
  }
  @keyframes hero-enter {
    from { opacity: 0; transform: scale(1.06); }
    to   { opacity: 1; transform: scale(1); }
  }
</style>
