---
import BaseLayout from "../../app/layouts/BaseLayout.astro";
---

<BaseLayout title="Blog — Alexandre Tortoza" description="Em breve: Pensamentos sobre tecnologia, desenvolvimento e experimentos.">
  <div class="mx-auto flex min-h-[calc(100vh-200px)] w-full max-w-[1440px] items-center justify-center px-6 py-12">
    <div class="m-10 flex h-full min-h-[400px] w-full items-center justify-center rounded-sm border border-white/5 bg-white/[0.03] backdrop-blur-md sm:m-32 lg:m-64">
      <div class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-8 py-4 backdrop-blur-sm">
        <span class="text-xs font-bold tracking-[0.3em] uppercase text-white/80">
          Em Construção 🏗️
        </span>
      </div>
    </div>
  </div>
</BaseLayout>
